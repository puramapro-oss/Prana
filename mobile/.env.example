EXPO_PUBLIC_SUPABASE_URL=https://auth.purama.dev
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_APP_URL=https://prana.purama.dev

# E2E test bypass — accepts prana://e2e/session?token=<access>\t<refresh> deep links.
# DO NOT enable in production builds. Only in dev/preview profiles for Maestro CI.
EXPO_PUBLIC_E2E_BYPASS=0

# ----- MANUAL — set once Tissma has the Apple/Google accounts ready -----
# Then run: eas init (writes projectId into app.json automatically)
# Then run: eas credentials  (sets up keychain + provisioning profiles)
#
# EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx     # from `eas init`
# APPLE_TEAM_ID=ABCDE12345                                  # from developer.apple.com
# APPLE_ASC_APP_ID=1234567890                               # from App Store Connect after first build
# GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json # downloaded from Google Cloud Console
