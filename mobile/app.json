{
  "expo": {
    "name": "PURAMA ONE",
    "slug": "prana",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "prana",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "primaryColor": "#7C3AED",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.purama.prana",
      "associatedDomains": [
        "applinks:prana.purama.dev",
        "applinks:purama.dev"
      ],
      "infoPlist": {
        "NSMicrophoneUsageDescription": "PURAMA ONE utilise le micro pour la capture vocale LifeOS et la TTS guidée des protocoles de respiration.",
        "NSHealthShareUsageDescription": "PURAMA ONE lit ton activité (pas, sommeil, fréquence cardiaque) pour personnaliser tes protocoles de régulation.",
        "NSHealthUpdateUsageDescription": "PURAMA ONE écrit tes sessions de respiration (Mindful Minutes) dans Apple Santé.",
        "NSUserTrackingUsageDescription": "PURAMA ONE ne pratique aucun suivi publicitaire. Cette autorisation permet uniquement la mesure d'engagement opt-in.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "dev.purama.prana",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_MINDFULNESS",
        "android.permission.health.WRITE_MINDFULNESS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "prana.purama.dev" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": { "deploymentTarget": "16.0" },
          "android": { "compileSdkVersion": 35, "targetSdkVersion": 35, "minSdkVersion": 26 }
        }
      ],
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "healthSharePermission": "Lire ton activité pour personnaliser les protocoles.",
          "healthUpdatePermission": "Écrire tes sessions de respiration dans Santé."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    },
    "owner": "puramapro-oss",
    "runtimeVersion": { "policy": "appVersion" },
    "updates": {
      "url": "https://u.expo.dev/00000000-0000-0000-0000-000000000000"
    }
  }
}
