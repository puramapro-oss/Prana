.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.secrets

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# sentry
.sentryclirc

# scripts (private credentials)
google-service-account.json
google-service-account*.json
*.keystore

# bootstrap stash (cleanup)
.bootstrap-stash/

# Claude Code working docs (contain secrets / large context)
CLAUDE.md
